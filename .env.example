# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.
# All variables are optional — sensible defaults are used for anything omitted.
#
# Loaded automatically by pydantic-settings from the working directory.
# Real environment variables always take precedence over .env values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Chat UI ──────────────────────────────────────────────────────────────────

# Team name shown in the assistant header, empty state, and page <title>.
# Rendered as "<CHAT_TEAM_NAME> Assistant".
CHAT_TEAM_NAME=Platform

# Short text (2–4 chars) used inside the logo mark and message avatars.
CHAT_LOGO_TEXT=plt

# Subtitle line shown under the team name in the header and empty state.
CHAT_TAGLINE="ask me anything"

# Welcome message shown before the user sends their first message.
CHAT_WELCOME_MESSAGE="Ask me anything — I'm here to help with questions, tasks, and anything your team needs."

# Placeholder text inside the chat textarea.
CHAT_INPUT_PLACEHOLDER="Ask anything..."

# Suggestion chips shown on the empty state. Must be a valid JSON array.
# Leave empty to use the built-in defaults.
CHAT_SUGGESTIONS="["Summarise our last sprint","Help me write a runbook","What's the on-call rotation?","Draft a post-mortem template"]"


# ── Paths ─────────────────────────────────────────────────────────────────────

# Absolute (or relative) path to the directory containing:
#   chat.html, index.html, _navbar.html   (Jinja2 templates)
#   static/                               (CSS and JS assets)
#
# Defaults to the directory containing config.py — only set this if your
# templates and static files live somewhere other than the package directory.
# BASE_DIR=/app/frontend
